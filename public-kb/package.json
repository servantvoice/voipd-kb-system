{
  "name": "@sv-kb/public-site",
  "version": "1.0.0",
  "private": true,
  "description": "Public knowledge base — Hugo site deployed to CF Pages",
  "scripts": {
    "fetch": "npx tsx scripts/fetch-content.ts",
    "build": "npm run fetch && hugo --baseURL ${KB_DOMAIN_URL:-https://example.com/}",
    "dev": "hugo server -D"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
