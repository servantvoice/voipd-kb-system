# Copy to .dev.vars — NEVER commit .dev.vars
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cf-api-token
CRAWL_SECRET=your-shared-secret
# Pipeline worker URL — crawl worker POSTs here after crawl completes
PIPELINE_URL=https://your-pipeline-worker.workers.dev
# Max pages per crawl job. Default 1000, API max 100000.
# Increase if your sitemap grows past ~900 pages.
# CRAWL_PAGE_LIMIT=1000
# Browser Rendering cache age in seconds. Default 86400 (24 hours).
# Set to 0 to disable caching (always fetch fresh). Max 604800 (7 days).
# CRAWL_MAX_AGE_SECONDS=86400
