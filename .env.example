# ─── Master Environment Configuration ──────────────────────────────────
#
# Copy this file to .env.private (gitignored) and fill in your values.
# Then run: bash scripts/setup-env.sh
# This distributes the correct variables to each worker's .dev.vars file
# and to public-kb/.dev.vars for local Hugo development.
#
# To push non-secret vars to Cloudflare production:
#   bash scripts/push-vars.sh
#
# Secrets (marked [SECRET] below) must be set separately:
#   bash scripts/push-vars.sh --secrets
#
# ───────────────────────────────────────────────────────────────────────

# ─── Cloudflare Account ────────────────────────────────────────────────
CF_ACCOUNT_ID=

# ─── Domains ──────────────────────────────────────────────────────────
KB_DOMAIN=
INTERNAL_KB_DOMAIN=
IMAGE_DOMAIN=
MANAGER_PORTAL_URL=
UPSTREAM_DOCS_URL=https://voipdocs.io

# ─── Branding ─────────────────────────────────────────────────────────
BRAND_NAME=
CONNECT_NAME=
CONNECT_DESKTOP_NAME=
SITE_TITLE=

# ─── Upstream Image CDNs ──────────────────────────────────────────────
SOURCE_IMAGE_CDN=cdn.elev.io
ADDITIONAL_IMAGE_SOURCES=[{"hostname":"static.helpjuice.com","pathPrefix":""},{"hostname":"t24555569.p.clickup-attachments.com","pathPrefix":"clickup/"}]

# ─── Image Sync Tuning ────────────────────────────────────────────────
REVALIDATE_HOURS=24
MAX_CONCURRENT=5

# ─── Admin ─────────────────────────────────────────────────────────────
ADMIN_EMAILS=["admin@example.com"]
EDITOR_EMAILS=[]
VIEWER_EMAILS=[]
NOTIFICATION_TO=
NOTIFICATION_FROM=

# ─── Downstream Triggers ──────────────────────────────────────────────
PAGES_DEPLOY_HOOK=
IMAGE_SYNC_URL=

# ─── Hugo Public Site (CF Pages env vars) ──────────────────────────────
# These are set in the CF Pages project, not on Workers.
# KB_DOMAIN_URL is used by the build command: hugo --baseURL $KB_DOMAIN_URL
KB_DOMAIN_URL=
HUGO_TITLE=
HUGO_PARAMS_DESCRIPTION=
HUGO_PARAMS_COMPANYNAME=
HUGO_PARAMS_COMPANYURL=
HUGO_PARAMS_LOGOURL=
HUGO_PARAMS_INTERNALKBURL=
HUGO_PARAMS_MANAGERPORTALURL=
HUGO_PARAMS_BILLINGPORTALURL=
HUGO_PARAMS_STATUSURL=

# ─── R2 API Credentials (for Hugo fetch script) ───────────────────────
# Create an R2 API token in CF dashboard (R2 > Manage R2 API Tokens)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=

# ─── Secrets [SECRET] ─────────────────────────────────────────────────
# These are pushed via `wrangler secret put` (encrypted at rest).
# They also go in .dev.vars for local development.
CRAWL_SECRET=
CF_API_TOKEN=
POSTMARK_API_TOKEN=
# Or if using Resend instead of Postmark:
# RESEND_API_KEY=
